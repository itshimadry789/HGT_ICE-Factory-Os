CORS_ORIGIN=http://localhost:3000

# n8n Webhook Configuration
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_SECRET_TOKEN=

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
